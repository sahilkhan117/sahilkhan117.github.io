---
import '../../global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{title}</title>
    <meta name="title" content="Sahil Khan | Full Stack Web Developer | GEN AI/ML Automation" />
    <meta name="description" content="Hi, I'm Sahil. I turn complex problems into elegant, high-performance web solutions. Check out my latest projects, skills, and coding journey." />
    
    <link rel="canonical" href="https://sahilkhan117.github.io/" />
    <link rel="icon" type="image/svg+xml" href="/DP-BRqT9_Lp.png" />
    <link rel="apple-touch-icon" href="/DP-BRqT9_Lp.png" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://sahilkhan117.github.io/" />
    <meta property="og:title" content="Full Stack Web Developer | Sahil Khan" />
    <meta property="og:description" content="Hi, I'm Sahil. I turn complex problems into elegant, high-performance web solutions." />
    <meta property="og:image" content="https://sahilkhan117.github.io/DP.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
